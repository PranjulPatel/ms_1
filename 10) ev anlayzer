class EVChargingAnalyzer:
  def create_sessions_df(self,session_data:list)->pd.DataFrame:
    cols=["SessionID","StationID","City","ChargingDate","EnergyKWh","DurationMinutes","PaymentStatus"]
    df=pd.DataFrame(session_data,columns=cols)
    return df

  def clean_sessions_data(self,pd.DataFrame)->pd.DataFrame:
    new_df=df.copy()
    new_df=new_df.dropna(subset=["SessionID","StationID","City","PaymentStatus"])
    new_df=new_df[new_df["EnergyKWh"]>0]
    new_df=new_df[new_df["DurationMinutes"]>0]

    status=["Paid","Pending","Failed"]
    new_df=new_df[new_df["PaymentStatus"].isin(status)]
    return new_df

  def add_long_session_flag(self,df:pd.DataFrame,duration_threshold:int)->pd.DataFrame:
    new_df=df.copy()
    new_df["IsLongSession"]=np.where(new_df["DurationMinutes"]>duration_threshold,1,0)
    return new_df

