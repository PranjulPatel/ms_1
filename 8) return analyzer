    def clean_returns_data(self,returns_df:pd.DataFrame)->pd.DataFrame:
        df_cleaned=returns_df.dropna(subset=["Reason"]).copy()
        df_cleaned=df_cleaned[df_cleaned["RefundAmount"].notnull()]
        df_cleaned=df_cleaned[df_cleaned["RefundAmount"]>0]
        df_cleaned=df_cleaned.reset_index(drop=True)
        return df_cleaned
