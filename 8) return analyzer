import pandas as pd

class ReturnsAnalyzer:
    def __init__(self):
        pass

    def create_orders_df(self,order_data:list)->pd.DataFrame:
        df=pd.DataFrame(order_data,columns=["OrderID","SellerID","Category","OrderDate","OrderAmount"])
        return df

    def create_returns_df(self,return_data:list)->pd.DataFrame:
        df=pd.DataFrame(return_data,columns=["OrderID","ReturnDate","RefundAmount","Reason"])
        return df

    def merge_orders_returns(self,orders_df:pd.DataFrame,returns_df:pd.DataFrame)->pd.DataFrame:
        merged=pd.merge(orders_df,returns_df,on="OrderID",how="left")
        return merged

